# Application
VITE_APP_NAME=Bablons Travel
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# API Configuration
VITE_API_BASE_URL=http://localhost:5000/api
VITE_API_TIMEOUT=10000

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_BOOKING=false
VITE_ENABLE_PAYMENT=false
VITE_ENABLE_REVIEWS=false
VITE_ENABLE_CHAT=false
VITE_ENABLE_NOTIFICATIONS=false

# Social Media
VITE_FACEBOOK_URL=https://facebook.com/bablonstravel
VITE_INSTAGRAM_URL=https://instagram.com/bablonstravel
VITE_TWITTER_URL=https://twitter.com/bablonstravel
VITE_WHATSAPP_NUMBER=+1234567890

# Maps
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Debug
VITE_DEBUG_MODE=false
